# Flutterwave Payment Gateway
# Get these from your Flutterwave dashboard: https://dashboard.flutterwave.com/
# Live keys (production):
# VITE_FLW_PUBLIC_KEY=FLWPUBK_live_xxxxxxxxxxxxx
# Test keys (development):
VITE_FLW_PUBLIC_KEY=FLWPUBK_TEST_xxxxxxxxxxxxx

# Payment gateway mode: flutterwave or central
VITE_PAYMENT_GATEWAY_MODE=flutterwave

# Optional central gateway integration (kept for fallback only)
VITE_CENTRAL_PAYMENT_GATEWAY_URL=https://your-central-gateway-app.com/checkout
VITE_CENTRAL_PAYMENT_CALLBACK_URL=https://your-backend.onrender.com/api/payments/gateway/callback

# Backend API URL
VITE_API_URL=https://your-backend.onrender.com
