# Database
MONGO_URI=your-mongodb-connection-string-here

# Google Sheets (for data sync)
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYourPrivateKeyContentHere\n-----END PRIVATE KEY-----

# Email Configuration
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-specific-password-here
RESEND_API_KEY=your-resend-api-key-here

# Cloudinary (Image hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name-here
CLOUDINARY_API_KEY=your-api-key-here
CLOUDINARY_API_SECRET=your-api-secret-here

# Frontend URL
FRONTEND_URL=https://xcombinator.com.ng

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
SUPER_ADMIN_EMAIL=admin@xcombinator.com

# NIN API Configuration
NIN_API_KEY=your-nin-api-key-here
NIN_VERIFY_URL=https://ninbvnportal.com.ng/api/nin-verification
NIN_PHONE_URL=https://ninbvnportal.com.ng/api/nin-phone
NIN_TRACKING_URL=https://ninbvnportal.com.ng/api/nin-tracking
NIN_DEMOGRAPHY_URL=https://ninbvnportal.com.ng/api/nin-demography

# Paystack Payment Gateway
# Get these from your Paystack dashboard: https://dashboard.paystack.com/
# Live keys (production):
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
# Test keys (development):
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Server
PORT=5000
NODE_ENV=production