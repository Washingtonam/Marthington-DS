# Database
MONGO_URI=your-mongodb-connection-string-here

# Google Sheets (for data sync)
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYourPrivateKeyContentHere\n-----END PRIVATE KEY-----

# Email Configuration
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-specific-password-here
RESEND_API_KEY=your-resend-api-key-here

# Cloudinary (Image hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name-here
CLOUDINARY_API_KEY=your-api-key-here
CLOUDINARY_API_SECRET=your-api-secret-here

# Frontend URL
FRONTEND_URL=https://xcombinator.com.ng

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
SUPER_ADMIN_EMAIL=admin@xcombinator.com

# NIN API Configuration
NIN_API_KEY=your-nin-api-key-here
NIN_VERIFY_URL=https://ninbvnportal.com.ng/api/nin-verification
NIN_PHONE_URL=https://ninbvnportal.com.ng/api/nin-phone
NIN_TRACKING_URL=https://ninbvnportal.com.ng/api/nin-tracking
NIN_DEMOGRAPHY_URL=https://ninbvnportal.com.ng/api/nin-demography

# Flutterwave Payment Gateway
# Get these from your Flutterwave dashboard: https://dashboard.flutterwave.com/
# Live keys (production):
# FLW_PUBLIC_KEY=FLWPUBK_live_xxxxxxxxxxxxx
# FLW_SECRET_KEY=FLWSECK_live_xxxxxxxxxxxxx
# FLW_SECRET_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Test keys (development):
FLW_PUBLIC_KEY=FLWPUBK_TEST_xxxxxxxxxxxxx
FLW_SECRET_KEY=FLWSECK_TEST_xxxxxxxxxxxxx
FLW_SECRET_HASH=your-flutterwave-webhook-hash-here
FLW_API_BASE_URL=https://api.flutterwave.com
FLW_PAYMENT_SOURCE=marthington
FLW_OPAY_SUBACCOUNT_ID=your-opay-subaccount-id-here

# Secure callback URL for wallet funding
# Render backend: https://your-backend.onrender.com/api/payments/webhook
# Vercel frontend: https://your-frontend.vercel.app/wallet?flutterwave=success
FRONTEND_URL=https://your-frontend.vercel.app

# OPay subaccount ID (optional)
FLW_OPAY_SUBACCOUNT_ID=your-opay-subaccount-id-here

# Central payment gateway bridge
CENTRAL_PAYMENT_GATEWAY_URL=https://your-central-gateway-app.com/checkout
CENTRAL_PAYMENT_GATEWAY_SECRET=your-central-gateway-shared-secret
CENTRAL_PAYMENT_CALLBACK_URL=http://localhost:5000/api/payments/gateway/callback
BACKEND_URL=http://localhost:5000

# Server
PORT=5000
NODE_ENV=production